{
  "version": 1,
  "hooks": {
    "sessionStart": [
         {
    "type": "command",
    "bash": "echo \"Session started: $(date)\" >> logs/session.log",
    "powershell": "Add-Content -Path logs/session.log -Value \"Session started: $(Get-Date)\"",
    "cwd": ".",
    "timeoutSec": 10
  }
    ],
    "sessionEnd": [
         {
    "type": "command",
    "bash": "echo \"Session ended: $(date)\" >> logs/session.log",
    "powershell": "Add-Content -Path logs/session.log -Value \"Session ended: $(Get-Date)\"",
    "cwd": ".",
    "timeoutSec": 10
  }
    ],
    "userPromptSubmitted": [
          {
    "type": "command",
    "bash": "./scripts/log-prompt.sh",
    "powershell": "./scripts/log-prompt.ps1",
    "cwd": "scripts",
    "env": {
      "LOG_LEVEL": "INFO"
    }
  }
    ],
    "preToolUse": [
            {
    "type": "command",
    "bash": "echo \"Tool about to be used: $TOOL_NAME\" >> logs/tools.log",
    "powershell": "Add-Content -Path logs/tools.log -Value \"Tool about to be used: $env:TOOL_NAME\"",
    "cwd": ".",
    "timeoutSec": 10
  }
    ],
    "postToolUse": [
            {
    "type": "command",
    "bash": "echo \"Tool used: $TOOL_NAME\" >> logs/tools.log",
    "powershell": "Add-Content -Path logs/tools.log -Value \"Tool used: $env:TOOL_NAME\"",
    "cwd": ".",
    "timeoutSec": 10
  }
    ],
    "errorOccurred" : [
          {
    "type": "command",
    "bash": "echo \"Error occurred: $ERROR_MESSAGE\" >> logs/errors.log",
    "powershell": "Add-Content -Path logs/errors.log -Value \"Error occurred: $env:ERROR_MESSAGE\"",
    "cwd": ".",
    "timeoutSec": 10
  }
    ]
  }
}
